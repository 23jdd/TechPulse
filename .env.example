APP_ENV=prod
HTTP_PORT=8080
GATEWAY_PORT=8080

# Docker build mirrors for China mainland networks.
GOPROXY=https://goproxy.cn,direct
ALPINE_MIRROR=https://mirrors.aliyun.com/alpine

MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=techpulse
MYSQL_PORT=3306
MYSQL_DSN=root:password@tcp(mysql:3306)/techpulse?parseTime=true&charset=utf8mb4&multiStatements=true

REDIS_PORT=6379
REDIS_ADDR=redis:6379

RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

ETCD_PORT=2379
ETCD_ENDPOINTS=etcd:2379

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=techpulse
GATEWAY_INTERNAL_URL=http://gateway:8080

AI_PROVIDER=mock
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
# Local LLM option:
# AI_PROVIDER=ollama
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.1

BLEVE_INDEX_PATH=/app/data/gateway-bleve

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/github/callback

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

DEFAULT_USER_ID=1
TECHPULSE_TAG=latest
